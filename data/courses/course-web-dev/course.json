        {
            "id": "unit-wd-02",
            "title": "Module 2: JavaScript",
            "order": 2,
            "slides": [
                {
                    "id": "wd-s05",
                    "order": 1,
                    "type": "html",
                    "title": "JavaScript Basics",
                    "content": {
                        "html": "<h2>JavaScript Basics</h2><p>JavaScript adds <strong>interactivity</strong> to web pages. Core concepts:</p><ul><li><strong>Variables</strong>: <code>let name = \"Ahmed\";</code></li><li><strong>Functions</strong>: <code>function greet() { alert(\"Hi!\"); }</code></li><li><strong>Events</strong>: <code>button.addEventListener(\"click\", greet);</code></li><li><strong>DOM</strong>: <code>document.getElementById(\"demo\").textContent = \"Hello\";</code></li></ul>",
                        "layout": "default"
                    }
                },
                {
                    "id": "wd-s06",
                    "order": 2,
                    "type": "quiz",
                    "title": "JavaScript Quiz",
