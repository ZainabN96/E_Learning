                    "title": "Data Types",
                    "content": {
                        "interaction_type": "accordion",
                        "instructions": "Open each section to learn Python data types.",
                        "completion_condition": "all_panels_opened",
                        "panels": [
                            {
                                "id": "pyp1",
                                "label": "Numbers",
                                "html": "<code>x = 5 &nbsp; # int<br>y = 3.14 # float<br>z = 2+3j # complex</code>"
                            },
                            {
                                "id": "pyp2",
                                "label": "Strings",
                                "html": "<code>s = \"Hello\"<br>s.upper() → \"HELLO\"<br>f\"Value: {x}\" → f-string</code>"
                            },
                            {
                                "id": "pyp3",
                                "label": "Lists & Dicts",
                                "html": "<code>lst = [1, 2, 3] &nbsp; # list<br>d = {\"key\": \"val\"} # dict<br>t = (1, 2) &nbsp; &nbsp; &nbsp; &nbsp; # tuple</code>"
                            }
                        ]
                    }
                },
                {
                    "id": "py-s03",
                    "order": 3,
                    "type": "html",
                    "title": "Control Flow",
                    "content": {
                        "html": "<h2>Control Flow</h2><pre style=\"background:#f3f4f6;padding:1rem;border-radius:6px;font-size:.85rem\"># If / else\\nif age >= 18:\\n    print(\"Adult\")\\nelse:\\n    print(\"Minor\")\\n\\n# For loop\\nfor i in range(5):\\n    print(i)\\n\\n# While loop\\ncount = 0\\nwhile count &lt; 3:\\n    count += 1</pre>",
                        "layout": "default"
                    }
                }
            ]
        },
        {
            "id": "unit-py-02",
            "title": "Module 2: Functions & OOP",
            "order": 2,
            "slides": [
                {
                    "id": "py-s04",
                    "order": 1,
                    "type": "html",
                    "title": "Functions",
                    "content": {
                        "html": "<h2>Functions in Python</h2><pre style=\"background:#f3f4f6;padding:1rem;border-radius:6px;font-size:.85rem\">def greet(name, greeting=\"Hello\"):\\n    return f\"{greeting}, {name}!\"\\n\\nprint(greet(\"Ali\"))          # Hello, Ali!\\nprint(greet(\"Sara\", \"Hi\"))   # Hi, Sara!\\n\\n# Lambda\\nsquare = lambda x: x ** 2\\nprint(square(4))             # 16</pre>",
                        "layout": "default"
                    }
                },
                {
                    "id": "py-s05",
                    "order": 2,
                    "type": "html",
                    "title": "Object-Oriented Programming",
                    "content": {
                        "html": "<h2>OOP Concepts</h2><pre style=\"background:#f3f4f6;padding:1rem;border-radius:6px;font-size:.85rem\">class Animal:\\n    def __init__(self, name):\\n        self.name = name\\n    def speak(self):\\n        return f\"{self.name} makes a sound\"\\n\\nclass Dog(Animal):\\n    def speak(self):\\n        return f\"{self.name} barks!\"\\n\\nd = Dog(\"Rex\")\\nprint(d.speak())  # Rex barks!</pre>",
                        "layout": "default"
                    }
                },
